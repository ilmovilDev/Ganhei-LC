generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Day {
  id          String     @id @default(cuid())
  clerkId     String
  date        DateTime

  hours       Int
  kilometers  Int

  earnings    Earning[]
  expenses    Expense[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clerkId, date])
  @@unique([clerkId, date])
}

model Earning {
  id        String   @id @default(cuid())
  dayId     String

  app       App
  amount    Decimal  @db.Decimal(10, 2)

  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayId])
  @@index([app])

  @@unique([dayId, app])
}

model Expense {
  id        String   @id @default(cuid())

  dayId     String
  type      ExpenseType
  amount    Decimal  @db.Decimal(10, 2)
  note      String?  @db.VarChar(255)

  day       Day      @relation(fields: [dayId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dayId])
  @@index([type])
}

enum App {
  UBER
  INDRIVER
  NINE_NINE
  NINE_NINE_FOOD
  IFOOD
  DELIVERY
  SHOPEE
  OTHER
}

enum ExpenseType {
  FUEL
  FOOD
  MAINTENANCE
  MARKET
  TOLLS
  PARKING
  OTHER
}

